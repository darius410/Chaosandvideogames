---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { formatDate, slugify } from "../js/utils";
export const prerender = true;

const allBlogs = await getCollection("blogs");
const recentBlogs = [...allBlogs]
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 4);
---

<MainLayout
  title="Chaos And Video Games Homepage"
  role="main"
  description="Chaos and video games is a blogging site about the deeper understanding of video games and thier effect on the world as well as blogs about the lifestyle of coding.Whether you enjoy reading about coding trends or if you need a argumentive discussion about the current state of video game development,this website carries several topics that are sure to inform and educate you about video games."
>
  <div class="homeContainer lineBorderX">
    <section class="hero-shell" aria-label="Homepage introduction">
      <div class="hero-copy">
       
        <h1 class="hero-title">Welcome</h1>
        <p class="hero-description">
          Chaos and video games is a blogging site about the deeper
          understanding of video games and thier effect on the world as well as
          blogs about the lifestyle of coding.
        </p>
        <ul class="hero-points" role="list">
          <li>
            Whether you enjoy reading about coding trends or if you need a
            argumentive discussion about the current state of video game
            development,this website carries several topics that are sure to
            inform and educate you about video games.
          </li>
        </ul>
        <a class="hero-cta" href="/blogs/blog/">View All Blogs</a>
      </div>
      <div class="hero-visual">
        <img
          src="/img/cyborg.png"
          alt="Futuristic cyborg artwork"
          width="900"
          height="900"
          loading="eager"
          decoding="async"
        />
      </div>
    </section>

    <section class="recent-section" aria-labelledby="recent-posts-title">
      <div class="recentPostContainer">
        <div class="recentPostShader">
          <h2 id="recent-posts-title" class="recent-heading">
            Recent Posts
            <span>Fresh analysis and dev thoughts</span>
          </h2>
        </div>
      </div>

      <ul class="recentPostCard flex column" role="list">
        {
          recentBlogs.map((v) => (
            <li role="listitem">
              <a href={`/blogs/${slugify(v.slug)}/`}>
                <div class="postCardContainer flex">
                  <div class="postCardInfo">
                    <span />
                    <h3>{v.data.title}</h3>
                    <p class="subtitle">{v.data.subtitle}</p>
                    <p>{formatDate(v.data.publishDate)}</p>
                  </div>

                  <div class="postCardImage">
                    <img
                      src={v.data.image.src}
                      alt={v.data.image.alt}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</MainLayout>
