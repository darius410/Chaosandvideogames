---
import { formatDate } from "../../js/utils";
import { slugify } from "../../js/utils";

const { frontmatter, tagType, url } = Astro.props;
const { subtitle, desc, title, publishDate, author, tags, image, url: legacyUrl } = frontmatter;
const cardDescription = desc || subtitle || "Read this article";
const normalizedLegacyUrl = legacyUrl
  ? `/blogs/${String(legacyUrl)
      .replace(/^\.\.\//, "")
      .replace(/^\/+/, "")
      .replace(/\/+$/, "")}/`
  : undefined;
const generatedTitleUrl = `/blogs/${slugify(title)}/`;
const postUrl = url || normalizedLegacyUrl || generatedTitleUrl;

const Tag = tagType;
const postDate = new Date(publishDate);
const isoDate = postDate.toISOString();
const formattedDate = formatDate(postDate);
---

<article class="blogCard items-center justify-items-center">
  <a href={postUrl} class="blogCardLink">
    <small class="blogCardMeta"
      >{author} - <time datetime={isoDate}>{formattedDate}</time></small
    >
    <h2>{title}</h2>
    <Tag class="tags">{tags}</Tag>

    <img
      src={image.src}
      alt={image.alt}
      width="500"
      height="400"
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="descContainer">
      <p>{cardDescription}</p>
  </div>
</article>
